# ─── Backend (apps/api) ──────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# SQLite database path (relative to apps/api working directory)
DB_PATH=./data/dxm.db

# JWT secrets — change both in production, min 32 characters each
JWT_SECRET=change_this_in_production_min_32_chars
JWT_REFRESH_SECRET=different_secret_also_min_32_chars

# Cookie domain — set to .dxmpulse.com in production
COOKIE_DOMAIN=localhost

# CORS — frontend origin
WEB_ORIGIN=http://localhost:5173

# ─── Telegram (optional) ─────────────────────────────────────────────────────
# Workspace owners configure their own tokens via the Settings UI.
# These server-level vars are not required unless you want a shared default bot.
TELEGRAM_DEFAULT_BOT_TOKEN=

# ─── Billing — Chapa (wire when API keys are obtained) ───────────────────────
CHAPA_SECRET_KEY=
CHAPA_WEBHOOK_SECRET=

# ─── Admin API ────────────────────────────────────────────────────────────────
# Secret for the internal PATCH /admin/workspaces/:id/plan endpoint.
# Used by operators to manually activate plans (Telegram / offline payments).
# Required in production. Keep this strong and out of version control.
ADMIN_SECRET=change_this_secret_for_admin_api

# ─── SDK CDN ─────────────────────────────────────────────────────────────────
# Where dxm.js is served from — used to build install snippets in Onboarding.
# In dev, Vite serves the SDK dist/ folder at this URL.
SDK_CDN_URL=http://localhost:5173/sdk/dxm.js

# Optional public API URL for generated install snippets.
# When set, the API adds data-api-url="..." to generated snippets.
API_PUBLIC_URL=

# Dedicated secret for authenticated digest execution.
# Required in production for POST /digest/send-all.
DIGEST_CRON_SECRET=

# ─── Frontend (apps/web) ─────────────────────────────────────────────────────
# These are Vite variables (must be prefixed VITE_).
# Embedded at BUILD TIME — set before running `npm run build`.
VITE_API_URL=http://localhost:4000
VITE_SDK_CDN_URL=http://localhost:5173/sdk/dxm.js
