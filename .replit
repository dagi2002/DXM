modules = ["nodejs-20", "web", "bash"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.development]
PORT = "4000"
NODE_ENV = "development"
DB_PATH = "./data/dxm.db"
JWT_SECRET = "replit_dev_jwt_secret_min_32_chars_abc"
JWT_REFRESH_SECRET = "replit_dev_refresh_secret_min_32_chars_xyz"
COOKIE_DOMAIN = "localhost"
WEB_ORIGIN = "http://localhost:5000"
VITE_API_URL = "http://localhost:4000"
ADMIN_SECRET = "local-admin-secret-123"
SDK_CDN_URL = "http://localhost:5000/sdk/dxm.js"
VITE_SDK_CDN_URL = "http://localhost:5000/sdk/dxm.js"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "bash start.sh"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[ports]]
localPort = 4000
externalPort = 3000

[[ports]]
localPort = 5000
externalPort = 80

[deployment]
deploymentTarget = "vm"
run = ["bash", "-c", "npm run migrate -w apps/api && node apps/api/dist/index.js & npx serve apps/web/dist -l 5000 --no-clipboard"]
build = ["bash", "-c", "npm run build -w packages/sdk && npm run build -w apps/web && npm run build -w apps/api"]
