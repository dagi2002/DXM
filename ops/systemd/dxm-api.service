[Unit]
Description=DXM Pulse API
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=dxm
Group=dxm
WorkingDirectory=/opt/dxm-pulse/app/apps/api
EnvironmentFile=/etc/dxm-pulse.env
ExecStart=/usr/bin/node /opt/dxm-pulse/app/apps/api/dist/index.js
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
